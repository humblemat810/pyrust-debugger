{
  "name": "pyrust-debugger",
  "displayName": "PyRust Debugger",
  "description": "Fixture-bound mixed Python and Rust stack debugger.",
  "version": "0.0.3",
  "publisher": "pyrust",
  "license": "UNLICENSED",
  "engines": {
    "vscode": "^1.125.0"
  },
  "categories": [
    "Debuggers"
  ],
  "extensionKind": [
    "workspace"
  ],
  "activationEvents": [
    "onDebug",
    "onView:pyrustProcessTree"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "views": {
      "debug": [
        {
          "id": "pyrustProcessTree",
          "name": "PyRust Process Tree"
        }
      ]
    },
    "commands": [
      {
        "command": "pyrust.focusThread",
        "title": "PyRust: Focus Process-Tree Thread"
      },
      {
        "command": "pyrust.focusFrame",
        "title": "PyRust: Focus Process-Tree Stack Frame"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "pyrust.focusThread",
          "when": "false"
        },
        {
          "command": "pyrust.focusFrame",
          "when": "false"
        }
      ]
    },
    "configuration": {
      "title": "PyRust Debugger",
      "properties": {
        "pyrust.pythonPath": {
          "type": "string",
          "default": "${workspaceFolder}/.venv/bin/python",
          "description": "CPython 3.14 executable used to launch the PyRust DAP adapter."
        },
        "pyrust.adapterPath": {
          "type": "string",
          "default": "${workspaceFolder}/prototype/adapter/__main__.py",
          "description": "Path to the PyRust DAP adapter entry point."
        },
        "pyrust.codelldbPath": {
          "type": "string",
          "default": "",
          "description": "Explicit CodeLLDB adapter executable. PYRUST_CODELLDB is used when empty."
        },
        "pyrust.liblldbPath": {
          "type": "string",
          "default": "",
          "description": "Explicit bundled liblldb path. PYRUST_LIBLLDB is used when empty."
        }
      }
    },
    "debuggers": [
      {
        "type": "pyrust",
        "label": "PyRust",
        "languages": [
          "python",
          "rust"
        ],
        "configurationAttributes": {
          "launch": {
            "required": [
              "program"
            ],
            "properties": {
              "program": {
                "type": "string",
                "description": "Absolute path to the Python or Rust program."
              },
              "args": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "default": []
              },
              "cwd": {
                "type": "string",
                "default": "${workspaceFolder}"
              },
              "env": {
                "type": "object",
                "additionalProperties": {
                  "type": "string"
                },
                "default": {}
              },
              "terminal": {
                "type": "string",
                "enum": [
                  "console",
                  "integrated",
                  "external"
                ],
                "default": "console"
              },
              "consoleMode": {
                "type": "string",
                "enum": [
                  "commands",
                  "evaluate",
                  "split"
                ],
                "default": "evaluate",
                "description": "CodeLLDB Debug Console behavior."
              },
              "sourceLanguages": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "default": [
                  "rust"
                ]
              },
              "pyrustChildRegistryPath": {
                "type": "string",
                "description": "Directory used to register child processes in PyRust child coordinator mode."
              },
              "pyrustProcessMode": {
                "type": "string",
                "enum": [
                  "native",
                  "children"
                ],
                "default": "native",
                "description": "Use children to launch the parent directly and attach CodeLLDB only to registered child processes."
              },
              "pyrustThreadMode": {
                "type": "string",
                "enum": [
                  "all",
                  "single"
                ],
                "default": "all",
                "description": "Use single only when a child fixture requires per-thread continuation."
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "type": "pyrust",
            "request": "launch",
            "name": "PyRust: Python Outer",
            "program": "${workspaceFolder}/.venv/bin/python",
            "args": [
              "${workspaceFolder}/research/fixtures/python_outer/app.py"
            ],
            "cwd": "${workspaceFolder}",
            "terminal": "console",
            "consoleMode": "evaluate",
            "sourceLanguages": [
              "rust"
            ]
          },
          {
            "type": "pyrust",
            "request": "launch",
            "name": "PyRust: Python Async",
            "program": "${workspaceFolder}/.venv/bin/python",
            "args": [
              "${workspaceFolder}/tests/acceptance/async_fixture_driver.py"
            ],
            "cwd": "${workspaceFolder}",
            "terminal": "console",
            "consoleMode": "evaluate",
            "sourceLanguages": [
              "rust"
            ]
          },
          {
            "type": "pyrust",
            "request": "launch",
            "name": "PyRust: Rust Async",
            "program": "${env:CARGO_TARGET_DIR}/debug/rust-outer-python-async",
            "args": [],
            "cwd": "${workspaceFolder}",
            "env": {
              "LD_LIBRARY_PATH": "${env:PYRUST_PYTHON_LIBDIR}"
            },
            "terminal": "console",
            "consoleMode": "evaluate",
            "sourceLanguages": [
              "rust"
            ]
          },
          {
            "type": "pyrust",
            "request": "launch",
            "name": "PyRust: Rust Outer",
            "program": "${env:CARGO_TARGET_DIR}/debug/rust-outer-python-inner",
            "args": [],
            "cwd": "${workspaceFolder}",
            "env": {
              "LD_LIBRARY_PATH": "${env:PYRUST_PYTHON_LIBDIR}"
            },
            "terminal": "console",
            "consoleMode": "evaluate",
            "sourceLanguages": [
              "rust"
            ]
          },
          {
            "type": "pyrust",
            "request": "launch",
            "name": "PyRust: Python Threads",
            "program": "${workspaceFolder}/.venv/bin/python",
            "args": [
              "${workspaceFolder}/tests/acceptance/threaded_fixture_driver.py"
            ],
            "cwd": "${workspaceFolder}",
            "terminal": "console",
            "consoleMode": "evaluate",
            "sourceLanguages": [
              "rust"
            ]
          },
          {
            "type": "pyrust",
            "request": "launch",
            "name": "PyRust: Rust Threads",
            "program": "${env:CARGO_TARGET_DIR}/debug/rust-outer-python-threads",
            "args": [],
            "cwd": "${workspaceFolder}",
            "env": {
              "LD_LIBRARY_PATH": "${env:PYRUST_PYTHON_LIBDIR}"
            },
            "terminal": "console",
            "consoleMode": "evaluate",
            "sourceLanguages": [
              "rust"
            ]
          },
          {
            "type": "pyrust",
            "request": "launch",
            "name": "PyRust: Python Processes",
            "program": "${workspaceFolder}/.venv/bin/python",
            "args": [
              "${workspaceFolder}/tests/acceptance/multiprocess_fixture_driver.py"
            ],
            "cwd": "${workspaceFolder}",
            "env": {
              "PYRUST_CHILD_REGISTRY": "${workspaceFolder}/.pyrust-child-registry"
            },
            "pyrustChildRegistryPath": "${workspaceFolder}/.pyrust-child-registry",
            "pyrustProcessMode": "children"
          },
          {
            "type": "pyrust",
            "request": "launch",
            "name": "PyRust: Rust Processes",
            "program": "${env:CARGO_TARGET_DIR}/debug/rust-outer-python-processes",
            "args": [],
            "cwd": "${workspaceFolder}",
            "env": {
              "PYRUST_CHILD_REGISTRY": "${workspaceFolder}/.pyrust-child-registry",
              "PYRUST_PYTHON": "${workspaceFolder}/.venv/bin/python",
              "PYRUST_PROCESS_WORKER": "${workspaceFolder}/tests/acceptance/multiprocess_worker.py"
            },
            "pyrustChildRegistryPath": "${workspaceFolder}/.pyrust-child-registry",
            "pyrustProcessMode": "children"
          },
          {
            "type": "pyrust",
            "request": "launch",
            "name": "PyRust: Process and Threads",
            "program": "${env:CARGO_TARGET_DIR}/debug/rust-outer-python-process-threads",
            "args": [],
            "cwd": "${workspaceFolder}",
            "env": {
              "PYRUST_CHILD_REGISTRY": "${workspaceFolder}/.pyrust-child-registry",
              "PYRUST_PYTHON": "${workspaceFolder}/.venv/bin/python",
              "PYRUST_PROCESS_THREAD_WORKER": "${workspaceFolder}/tests/acceptance/process_thread_worker.py"
            },
            "pyrustChildRegistryPath": "${workspaceFolder}/.pyrust-child-registry",
            "pyrustProcessMode": "children",
            "pyrustThreadMode": "single",
            "preLaunchTask": "PyRust: Build Rust Process and Threads"
          }
        ]
      }
    ]
  },
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('out', { recursive: true, force: true })\"",
    "compile": "tsc -p ./",
    "package": "vsce package --allow-missing-repository --out pyrust-debugger.vsix",
    "test:extension": "node ./out/test/runTest.js",
    "test:installed-extension": "node ./out/test/runInstalledTest.js",
    "test": "npm run compile && npm run package && npm run test:extension && npm run test:installed-extension"
  },
  "devDependencies": {
    "@types/node": "24.13.3",
    "@types/vscode": "1.125.0",
    "@vscode/test-electron": "3.0.0",
    "@vscode/vsce": "3.9.2",
    "typescript": "7.0.2"
  }
}
