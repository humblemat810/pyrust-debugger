{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "pyrust",
      "request": "launch",
      "name": "PyRust: Python Outer",
      "program": "${workspaceFolder}/.venv/bin/python",
      "args": [
        "${workspaceFolder}/research/fixtures/python_outer/app.py"
      ],
      "cwd": "${workspaceFolder}",
      "terminal": "console",
      "consoleMode": "evaluate",
      "sourceLanguages": [
        "rust"
      ],
      "preLaunchTask": "PyRust: Build Python Outer"
    },
    {
      "type": "pyrust",
